# Copy to compose.env before `docker compose up` (compose.env is gitignored).
#
# Each owning service uses its own database (sports_auth / sports_media /
# sports_notifications) on the shared Postgres instance. Set the
# *_DATABASE_URL variables below (Compose does not use DATABASE_URL).

# --- Secrets (use strong values outside local dev) ---
INTERNAL_API_KEY=change-me-internal-key
JWT_SECRET=change-me-jwt-secret

# --- Postgres (single instance, multiple databases) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Default DB created by the postgres image; the init script also creates
# sports_auth, sports_media, and sports_notifications.
POSTGRES_DB=postgres

# Per-service database URLs. These names match the bootstrap script at
# deploy/postgres/init-databases.sh.
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sports_auth
MEDIA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sports_media
NOTIFICATIONS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sports_notifications

# --- Shared JWT / HTTP config ---
JWT_ALGORITHM=HS256
JWT_ACCESS_EXP_MINUTES=60
PUBLIC_BASE_URL=http://localhost:8000

# --- Analytics ---
ANALYTICS_QUEUE=sports:analytics:jobs

# Redis (analytics work queue).
REDIS_URL=redis://redis:6379/0

# --- Docker Compose: app hot reload ---
# 1 = uvicorn --reload and watchfiles-based worker restarts when bind-mounted sources change (see docker-compose.yml).
UV_DEV_RELOAD=1
# Set false on native Linux if CPU use is high; Docker Desktop bind mounts often need true for reliable watching.
WATCHFILES_FORCE_POLLING=true
