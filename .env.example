# Local-dev .env for non-Docker runs. Each owning service uses its own
# *_DATABASE_URL. Migrations live under services/<name>/migrations; see README.

# Shared secrets / keys (DO NOT commit real values)
INTERNAL_API_KEY=change-me-internal-key
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXP_MINUTES=60

# --- Owning-service databases ---
AUTH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sports_auth
MEDIA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sports_media
NOTIFICATIONS_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sports_notifications

# --- Service hosts/ports ---
AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=8002

MEDIA_SERVICE_HOST=0.0.0.0
MEDIA_SERVICE_PORT=8004

NOTIFICATIONS_SERVICE_HOST=0.0.0.0
NOTIFICATIONS_SERVICE_PORT=8005

MAIN_SERVICE_HOST=0.0.0.0
MAIN_SERVICE_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000
UPLOAD_DIR=./uploads

ANALYTICS_SERVICE_HOST=0.0.0.0
ANALYTICS_SERVICE_PORT=8003
YOLO_MODEL_PATH=yolo26x.pt

# --- Service-to-service URLs (used by clients) ---
AUTH_SERVICE_URL=http://localhost:8002
MEDIA_SERVICE_URL=http://localhost:8004
NOTIFICATIONS_SERVICE_URL=http://localhost:8005
ANALYTICS_SERVICE_URL=http://localhost:8003

# --- Redis (analytics work queue) ---
REDIS_URL=redis://localhost:6379/0
ANALYTICS_QUEUE=sports:analytics:jobs
